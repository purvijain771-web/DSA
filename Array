Q. Sum of Array:-
#include <iostream>
using namespace std;

int main(){
  int arr[5];
  int sum = 0;
  for(int i=0; i<=4; i++){
    cin>>arr[i];
    sum+=arr[i];
  }
  cout<<sum;
  return 0;
}
