Q.1 2D Array find sum of all elements:-
#include <iostream>
using namespace std;

int main() {
    int sum = 0;
    int arr[2][2];

    for(int i = 0; i < 2; i++) {
        for(int j = 0; j < 2; j++) {
            cin >> arr[i][j];
            cout<<arr[i][j]<<" ";
            sum = sum + arr[i][j];
        }
        cout<<endl;
    }
    cout << "Sum of elements: " << sum << endl;
    return 0;
}
