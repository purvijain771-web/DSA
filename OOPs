#include <iostream>
using namespace std;
class Banking{
  public:
  string holderName;
  string address;
  int accountNumber;
  string bankName;
  Banking(){
    cout<<"default constructor called"<<endl;
  }
  Banking(string a){
    holderName=a;
    cout<<holderName<<endl;
  }
  Banking(string a,string b, int c, string d){
    this->holderName=a;
    this->address=b;
    this->accountNumber=c;
    this->bankName=d;
    cout<<holderName<<" "<<address<<" "<<accountNumber<<" "<<bankName<<endl;
  }
};
int main(){
  Banking obj("Purvi","Jaipur",12345678,"SBI");
  return 0;
}





#include <iostream>
using namespace std;
//Copy Constructor
class Student{
  public:
  string name;
  int age;
  int roll_no;
  //Parameterized Constructor
  Student(string name,int age,int roll_no){
    this->name=name;
    this->age=age;
    this->roll_no=roll_no;
    cout<<name<<" "<<age<<" "<<roll_no<<endl;
  }
  //Copy Constructor
  Student(Student &a){
    name=a.name;
    age=a.age;
    roll_no=a.roll_no;
  }
};
int main() 
{
    Student obj1("Purvi",20,1422);
    Student obj2(obj1);
    return 0;
}
