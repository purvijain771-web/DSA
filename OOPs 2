Q.1 Code for encapsulation and abstraction:-
#include <iostream>
using namespace std;
//Encapsulation/Abstraction
class Student{
  private:
  //Properties
  string name;
  int age;
  int marks;
  
  public:
  void setter(string n, int a, int m){
    name=n;
    age=a;
    marks=m;
  }
  int getter(){
    return age;
  }
};
int main(){
  Student obj;
  obj.setter("Purvi",20,85);
  cout<<obj.getter();
  return 0;
}
