Q.1 Binary Search:-
#include <iostream>
using namespace std;

int main(){
  int arr[5]={1,2,3,4,5};
  int n=5;
  int target;
  int s=0, e=n-1;
  while(s<=e){
    int mid=(s+e)/2;
    if(arr[mid] == target){
      return mid;
    }
    else if(arr[mid] < target){
      s = mid+1;
    }
    else{
      e = mid-1;
    }
  }
cout<<"-1";
return 0;
}
