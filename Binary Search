Q.2 First and last position:-
class Solution {
    int lowerBound(vector<int>&nums, int target){
        int s=0, e=nums.size()-1, ans=-1; 
       while(s<=e){
        int mid = (s+e)/2;
        if(nums[mid]==target){
          ans = mid;
          e = mid-1;
        }
        else if(nums[mid] < target){
           s = mid+1;
        }
        else{
          e = mid-1;
        }
       }
       return ans;
    }
    int upperBound(vector<int>&nums, int target){
        int s=0, e=nums.size()-1, ans=-1; 
       while(s<=e){
        int mid = (s+e)/2;
        if(nums[mid]==target){
          ans = mid;
          s = mid+1;
        }
        else if(nums[mid] < target){
           s = mid+1;
        }
        else{
          e = mid-1;
        }
       }
       return ans;
    }
public:
    vector<int> searchRange(vector<int>& nums, int target) {
        vector<int> arr;
       int first = lowerBound(nums,target);
       int last = upperBound(nums,target);
       arr.push_back(first);
       arr.push_back(last);
       return arr;
    }  
};
