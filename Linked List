Q.1 Insert and End at Singly Linked List:-
#include <iostream>
using namespace std;

// Structure of Node
class Node {
public:
    int val;
    Node *next;

    Node(int v) {
        val = v;
        next = NULL;
    }
};

// Insert at Start
void insertAtStart(Node* &head, Node* &tail) {
    if (head == NULL) {
        Node *n = new Node(2);
        head = n;
        tail = n;
    }
    else {
        Node *n = new Node(3);
        n->next = head;
        head = n;
    }
}

// Insert at End
void insertAtEnd(Node* &head, Node* &tail) {
    if (head == NULL) {
        Node *n = new Node(2);
        head = n;
        tail = n;
    }
    else {
        Node *n = new Node(4);
        tail->next = n;
        tail = n;
    }
}

// Display Linked List
void display(Node *head) {
    Node *temp = head;

    while (temp != NULL) {
        cout << temp->val << " ";
        temp = temp->next;
    }
}

int main() {

    Node *head = NULL;
    Node *tail = NULL;

    insertAtStart(head, tail);
    insertAtStart(head, tail);

    insertAtEnd(head, tail);

    display(head);

    return 0;
}
