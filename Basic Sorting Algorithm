Q.6 Two Sum == target 2nd :-
#include <iostream>
using namespace std;
//Two Pointer - Two Sum Array
int main(){
  int arr[4]={2,7,11,15};
  int n = 4;
  int target=9;
  int i=0, j=n-1;
  while(i<=j){
    if(arr[i]+arr[j] == target){
      cout<<i<<" "<<j<<endl;
      break;
    }
    else if(arr[i]+arr[j] > target){
      j--;
    }
    else{
      i++;
    }
  }
  return 0;
}
