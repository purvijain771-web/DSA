Q.5 Two Sum == target:-
#include <iostream>
using namespace std;
//Two Pointer - Two Sum Array
int main(){
  int arr[6]={2,4,6,4,2,8};
  int n = 6;
  int target=6;
  for(int i=0; i<=n-1; i++){
    for(int j=i+1; j<=n-1; j++){
      if(arr[i]+arr[j] == target){
        cout<<i<<" "<<j<<endl;
        break;
      }
    }
  }
  return 0;
}
