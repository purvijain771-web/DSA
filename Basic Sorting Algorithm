Q.4 Reverse Array:-
#include <iostream>
using namespace std;
//Two Pointer - Reverse Array
int main(){
  int arr[5]={5,4,3,2,1};
  int n = 5;
  int i=0 , j=n-1;
  while(i<=j){
    swap(arr[i],arr[j]);
    i++;
    j--;
  }
  for(int i=0; i<n; i++){
    cout<<arr[i]<<" ";
  }
  return 0;
}
