Q.3 Selection Sort:-
#include <iostream>
using namespace std;
//Insertion Sort : o(n^2)
int main(){
  int arr[5] = {5,4,3,2,1};
  int n=5;
  int min_ele_idx;
  for(int i=0; i<=n-1 ; i++){
    for(int j=i+1; j<=n-1; j++){
      if(arr[j]<arr[min_ele_idx]){
       min_ele_idx=j;
      }
    } 
     swap(arr[i],arr[min_ele_idx]);
  }
  //display sorted std
  for(int i=0; i<n; i++){
    cout<<arr[i]<<" ";
  }
  return 0;
}
