Q.4 Binary Search:-
using namespace std;

int binarySearch(int arr[], int target, int s, int e) {
    if (s > e) {
        return -1;
    }

    int mid = (s + e) / 2;

    if (arr[mid] == target) {
        return mid;
    }
    else if (arr[mid] < target) {
        return binarySearch(arr, target, mid + 1, e);
    }
    else {
        return binarySearch(arr, target, s, mid - 1);
    }
}

int main() {
    int arr[5] = {1, 2, 3, 4, 5};
    int target;

    cin >> target;

    int ans = binarySearch(arr, target, 0, 4);

    if (ans != -1) {
        cout << "Element found at idx: " << ans;
    }
    else {
        cout << "Element not found";
    }

    return 0;
}
